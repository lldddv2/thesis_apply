{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "bash",
      "args": [
        "manuscrito/compilation/compile.sh"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Nueva entrada (bitácora)",
      "type": "shell",
      "command": "node",
      "args": [
        "scripts/new-entry.js",
        "${input:entryTitle}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ],
  "inputs": [
    {
      "id": "entryTitle",
      "type": "promptString",
      "description": "Título de la entrada de la bitácora",
      "default": ""
    }
  ]
}
